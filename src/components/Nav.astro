---
const links = [
  { href: "#story", label: "Nuestra Historia" },
  { href: "#menu", label: "Menu" },
  { href: "#reservations", label: "Reservaciones" },
  { href: "#footer", label: "Ubicación" },
];
---

<header
  class="sticky top-0 z-50 border-b border-tertiary/10 bg-surface/90 backdrop-blur"
>
  <nav class="container-heritage flex items-center justify-between py-5">
    <a
      href="#"
      class="font-headline text-xl tracking-tight text-on-surface"
      aria-label="Cachi Pizza"
    >
      Cachi Pizza
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-body text-sm font-medium tracking-wide text-on-surface-variant transition-colors hover:text-on-surface"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a href="#reservations" class="btn-primary hidden md:inline-flex">
      Reservar Mesa
    </a>

    <button
      id="nav-toggle"
      class="inline-flex h-10 w-10 items-center justify-center text-on-surface md:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span class="material-symbols-outlined">menu</span>
    </button>
  </nav>

  <div id="nav-mobile" class="hidden border-t border-tertiary/10 md:hidden">
    <ul class="container-heritage flex flex-col gap-1 py-4">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="block py-3 font-body text-sm font-medium tracking-wide text-on-surface-variant"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <a href="#reservations" class="btn-primary w-full">Reservar Mesa</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const mobile = document.getElementById("nav-mobile");

  toggle?.addEventListener("click", () => {
    const isHidden = mobile?.classList.contains("hidden");
    mobile?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!!isHidden));
  });

  mobile?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => mobile.classList.add("hidden"));
  });
</script>
