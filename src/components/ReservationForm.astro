---
---

<section id="reservations" class="py-16 md:py-24">
  <div class="container-heritage">
    <div class="mx-auto max-w-2xl">
      <div class="text-center">
        <span class="font-body text-sm font-semibold uppercase tracking-[0.05em] text-secondary">
          Reservaciones
        </span>
        <h2 class="mt-4 font-headline text-[32px] font-semibold leading-[40px] text-on-surface">
          Reservar Mesa
        </h2>
        <p class="mt-3 font-body text-base leading-6 text-on-surface-variant">
          Separa tu lugar en la trattoria y vive la tradición de 1964.
        </p>
      </div>

      <form id="reservation-form" class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2">
        <div class="md:col-span-2">
          <label for="name" class="mb-2 block font-body text-sm font-semibold tracking-wide text-on-surface">
            Nombre completo
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Tu nombre"
            class="w-full border-0 border-b border-tertiary/40 bg-transparent px-1 py-3 font-body text-on-surface placeholder:text-on-surface-variant/50 focus:border-secondary focus:outline-none"
          />
        </div>

        <div class="md:col-span-2">
          <label for="email" class="mb-2 block font-body text-sm font-semibold tracking-wide text-on-surface">
            Correo electrónico
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="tucorreo@ejemplo.com"
            class="w-full border-0 border-b border-tertiary/40 bg-transparent px-1 py-3 font-body text-on-surface placeholder:text-on-surface-variant/50 focus:border-secondary focus:outline-none"
          />
        </div>

        <div>
          <label for="date" class="mb-2 block font-body text-sm font-semibold tracking-wide text-on-surface">
            Fecha
          </label>
          <input
            type="date"
            id="date"
            name="date"
            required
            class="w-full border-0 border-b border-tertiary/40 bg-transparent px-1 py-3 font-body text-on-surface focus:border-secondary focus:outline-none"
          />
        </div>

        <div>
          <label for="time" class="mb-2 block font-body text-sm font-semibold tracking-wide text-on-surface">
            Hora
          </label>
          <input
            type="time"
            id="time"
            name="time"
            required
            class="w-full border-0 border-b border-tertiary/40 bg-transparent px-1 py-3 font-body text-on-surface focus:border-secondary focus:outline-none"
          />
        </div>

        <div class="md:col-span-2">
          <label for="party-size" class="mb-2 block font-body text-sm font-semibold tracking-wide text-on-surface">
            Número de personas
          </label>
          <select
            id="party-size"
            name="party-size"
            required
            class="w-full border-0 border-b border-tertiary/40 bg-transparent px-1 py-3 font-body text-on-surface focus:border-secondary focus:outline-none"
          >
            <option value="" disabled selected>Selecciona una opción</option>
            <option value="1">1 persona</option>
            <option value="2">2 personas</option>
            <option value="3">3 personas</option>
            <option value="4">4 personas</option>
            <option value="5">5 personas</option>
            <option value="6">6 personas</option>
            <option value="7">7 personas</option>
            <option value="8+">8 o más personas</option>
          </select>
        </div>

        <div class="md:col-span-2">
          <button type="submit" class="btn-primary w-full">
            Confirmar Reserva
          </button>
          <p id="reservation-confirmation" class="mt-4 hidden text-center font-body text-sm text-secondary">
            Gracias, hemos recibido tu solicitud de reserva.
          </p>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const dateInput = document.getElementById("date") as HTMLInputElement | null;
  if (dateInput) {
    const now = new Date();
    const year = now.getFullYear();
    const month = String(now.getMonth() + 1).padStart(2, "0");
    const day = String(now.getDate()).padStart(2, "0");
    dateInput.min = `${year}-${month}-${day}`;
  }

  const form = document.getElementById("reservation-form") as HTMLFormElement | null;
  const confirmation = document.getElementById("reservation-confirmation");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    // UI-only for now, no backend wired up.
    confirmation?.classList.remove("hidden");
    form.reset();
  });
</script>
