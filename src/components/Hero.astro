---
---

<section class="relative flex min-h-[92vh] items-end overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1513104890138-7c749659a591?w=1600&q=80"
      alt="Pizza artesanal recién salida del horno de leña, con corteza dorada y quemada al carbón, en una trattoria en penumbra"
      class="h-full w-full object-cover"
      loading="eager"
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-surface via-surface/70 to-surface/20"
    >
    </div>
    <div class="absolute inset-0 bg-surface/30"></div>
  </div>

  <div class="container-heritage relative z-10 pb-20 pt-40 md:pb-28">
    <span class="chip-heritage mb-6">Dal 1964, Costa Rica</span>

    <h1
      class="max-w-3xl font-headline text-[40px] font-bold leading-[48px] tracking-tight text-on-surface md:text-[56px] md:leading-[64px] md:tracking-[-0.02em]"
    >
      La Auténtica Tradición Italiana
    </h1>

    <p
      class="mt-6 max-w-xl font-body text-lg leading-7 text-on-surface-variant"
    >
      Donde la herencia de una trattoria de los 60s se encuentra con la
      calidez de Costa Rica.
    </p>

    <div class="mt-10 flex flex-wrap gap-4">
      <a href="#menu" class="btn-primary">Ver Menú</a>
      <a href="#story" class="btn-secondary">Nuestra Historia</a>
    </div>
  </div>
</section>
