---
const legalLinks = [
  { href: "#", label: "Política de Privacidad" },
  { href: "#", label: "Términos" },
  { href: "#", label: "Trabaja con Nosotros" },
];
---

<footer id="footer" class="border-t border-tertiary/10 py-14">
  <div class="container-heritage">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <div>
        <span class="font-headline text-xl text-on-surface">Cachi Pizza</span>
        <p class="mt-3 font-body text-sm leading-5 text-on-surface-variant">
          Cachí, Cartago, Costa Rica
        </p>
        <p class="mt-1 font-body text-sm leading-5 text-on-surface-variant">
          Martes a Domingo, 12:00 pm - 9:30 pm
        </p>
      </div>

      <ul class="flex flex-col gap-3 md:flex-row md:gap-8">
        {
          legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-body text-sm text-on-surface-variant transition-colors hover:text-on-surface"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <hr class="divider-heritage my-10" />

    <p class="font-body text-xs text-on-surface-variant">
      © 1964 Cachi Pizza. Todos los derechos reservados.
    </p>
  </div>
</footer>
