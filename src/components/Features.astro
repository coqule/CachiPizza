---
const features = [
  {
    icon: "local_pizza",
    title: "Tradición Familiar desde 1964",
    description:
      "Tres generaciones amasando con la misma receta traída de Nápoli, sin atajos ni recetas industriales.",
  },
  {
    icon: "eco",
    title: "Raíces Italianas Auténticas",
    description:
      "Técnicas, tiempos de fermentación y horno de leña originales, respetados al detalle en cada pizza.",
  },
  {
    icon: "groups",
    title: "Ingredientes Locales Frescos",
    description:
      "Productores de la zona volcánica de Costa Rica surten nuestros quesos, vegetales y embutidos cada semana.",
  },
];
---

<section class="py-16 md:py-24">
  <div class="container-heritage">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-3 md:gap-8">
      {
        features.map((feature) => (
          <div class="rounded-lg border border-tertiary/10 bg-surface-container-low p-8 text-center">
            <span class="material-symbols-outlined text-secondary" style="font-size: 40px;">
              {feature.icon}
            </span>
            <h3 class="mt-5 font-headline text-xl font-semibold text-on-surface">
              {feature.title}
            </h3>
            <p class="mt-3 font-body text-sm leading-5 text-on-surface-variant">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
